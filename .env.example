# Copy to .env and fill in locally. Do not commit .env.
# Файл .env в .gitignore — не коммитьте реальные значения.

# Spec-kit: каталог фичи для скриптов `.specify/scripts/bash/*` (перекрывает имя git-ветки).
# Пример: ветка `008-phase-8`, а спека — `specs/001-media-playlist-broadcast`.
SPECIFY_FEATURE=001-media-playlist-broadcast

# PostgreSQL
# В Dev Container переменная DB_HOST=postgres задаётся в .devcontainer/devcontainer.json;
# username/password для dev см. .devcontainer/compose.yaml (POSTGRES_*).
# Локально без Docker: не задавайте DB_HOST — Rails подключится к PostgreSQL через Unix socket.
# DB_HOST=postgres

# Docker Hub / registry (Kamal: pull base images, private registry login)
# KAMAL_REGISTRY_USER=
# KAMAL_REGISTRY_PASSWORD=

# Optional: override seed admin password (db/seeds.rb)
# SEED_ADMIN_PASSWORD=
